# ==============================================================================
# SWIFTLLM — Docker configuration
# Copy to ".env" (in this docker/ directory) and edit. Both docker-compose and
# the swiftllmctl wrapper read it.   cp .env.example .env
# ==============================================================================

# ---- Image / OS selection ----------------------------------------------------
# Which base OS to build/run. swiftllmctl --ubuntu / --rhel override these.
SWIFTLLM_OS=ubuntu
# Full Dockerfile path (relative to repo root) and image tag.
SWIFTLLM_DOCKERFILE=docker/Dockerfile.ubuntu
SWIFTLLM_IMAGE=swiftllm:ubuntu-2.0.0
# Build target: "runtime" (slim, production) or "devel" (toolchain for rebuilds).
SWIFTLLM_TARGET=runtime

# ---- Build arguments (change → rebuild to update) ----------------------------
CUDA_VERSION=12.4.1
UBUNTU_VERSION=22.04          # used by Dockerfile.ubuntu
UBI_VERSION=ubi9             # used by Dockerfile.rhel
PYTHON_VERSION=3.10          # 3.10 for ubuntu, 3.11 for rhel (set per OS)
SWIFTLLM_FEATURES=cuda       # cuda (GPU) | cpu
CUDA_ARCHITECTURES=80;86;89;90   # GGUF/CUDA archs. Add 120 only with CUDA 13+.
BUILD_LLAMA=1                # 1 = build CUDA GGUF backend, 0 = skip (faster build)
RUST_VERSION=stable
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124   # use .../whl/cpu for CPU
TORCH_SPEC=torch torchvision
# Match these to your host user for clean bind-mount permissions (id -u / id -g).
SWIFTLLM_UID=1000
SWIFTLLM_GID=1000

# ---- "Dynamic" source selection ---------------------------------------------
# Leave URL empty to build from THIS local checkout (edit code → rebuild).
# To pin a published release instead, set URL + REF (a tag/branch/commit):
SWIFTLLM_GIT_URL=
SWIFTLLM_GIT_REF=
# Examples:
#   SWIFTLLM_GIT_URL=https://github.com/infrabrew/swiftllm
#   SWIFTLLM_GIT_REF=v2.0.1

# ---- Runtime: model + server -------------------------------------------------
# The model to serve (HuggingFace id, "repo:file.gguf", or a path under /models).
SWIFTLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct-GGUF:qwen2.5-0.5b-instruct-q4_k_m.gguf
SWIFTLLM_HOST=0.0.0.0
SWIFTLLM_PORT=8000
# Host port published on the machine (left side of the mapping).
SWIFTLLM_HOST_PORT=8000
# Where models live INSIDE the container (kept on a persistent volume).
SWIFTLLM_MODEL_DIR=/models

# ---- Runtime: optional tuning (only set what you need) -----------------------
SWIFTLLM_TENSOR_PARALLEL_SIZE=
SWIFTLLM_GPU_MEMORY_UTILIZATION=
SWIFTLLM_MAX_MODEL_LEN=
SWIFTLLM_QUANTIZATION=
SWIFTLLM_DTYPE=
SWIFTLLM_TRUST_REMOTE_CODE=
SWIFTLLM_ENABLE_PREFIX_CACHING=
SWIFTLLM_SERVE_ARGS=

# ---- Training / one-shot jobs (the "trainer" compose service) -----------------
# Host directory mounted at /data in the `trainer` service for datasets and
# (if you make it writable) outputs. Checkpoints are best written to /models.
# NOTE: swiftllm training is currently a simulated stub — see docs.
SWIFTLLM_DATA_HOST=./data

# ---- Secrets -----------------------------------------------------------------
# Bearer token required on the API when set (recommended if exposing the port).
SWIFTLLM_API_KEY=
# HuggingFace token for gated/private model downloads.
HF_TOKEN=

# ---- GPU ---------------------------------------------------------------------
# Which GPUs the container sees: "all" or a list like "0,1".
NVIDIA_VISIBLE_DEVICES=all
